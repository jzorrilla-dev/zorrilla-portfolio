            Contáctame
          </a>
        </div>
      </div>

      <div class="md:w-1/2 w-full max-w-sm md:max-w-md mt-10 md:mt-0 relative">
        <div
          class="aspect-square bg-gray-200 rounded-full overflow-hidden shadow-2xl border-4 border-cyan-500"
        >
          <div class="flex items-center justify-center h-full text-gray-500 text-4xl">
            [poner mi foto aquí]
          </div>
        </div>
        <div class="absolute -top-4 -left-4 w-12 h-12 bg-yellow-400 rounded-full opacity-60"></div>
        <div class="absolute bottom-4 -right-4 w-16 h-16 bg-blue-300 rounded-lg opacity-40"></div>
      </div>
    </div>
  </div>
</section>
