<section
  id="hero"
  class="py-20 sm:py-32 md:py-48 bg-gray-50 dark:bg-gray-900 dark:text-gray-100 dark:border-gray-900 transition-colors duration-500"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row items-center justify-between gap-12">
      <div class="md:w-1/2 text-center md:text-left">
        <p class="text-xl text-cyan-600 font-semibold mb-3 tracking-widest uppercase">
          Hola, soy Juan
        </p>

        <h1
          class="text-5xl md:text-7xl font-extrabold text-gray-900 dark:text-gray-100 leading-tight mb-4"
        >
          Desarrollador Web <br class="hidden sm:inline" /> Full Stack.
        </h1>

        <p class="text-lg text-gray-800 dark:text-gray-100 max-w-lg mx-auto md:mx-0 mb-8">
