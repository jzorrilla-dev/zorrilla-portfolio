---
import ReactIcon from './icons/ReactIcon.astro'
import AstroIcon from './icons/AstroIcon.astro'
import TailwindIcon from './icons/TailwindIcon.astro'
import LaravelIcon from './icons/LaravelIcon.astro'
import NodeIcon from './icons/NodeJSIcon.astro'
import PostgresIcon from './icons/PostgresIcon.astro'
import DockerIcon from './icons/DockerIcon.astro'
import GitIcon from './icons/GitIcon.astro'
import GithubIcon from './icons/GithubIcon.astro'
import JavaScriptIcon from './icons/JavaScriptIcon.astro'
import TypeScriptIcon from './icons/TypeScriptIcon.astro'
import PHPIcon from './icons/PHPIcon.astro'
import NextJSIcon from './icons/NextJSIcon.astro'
import AlpineJSIcon from './icons/AlpineJSIcon.astro'

type IconKey = keyof typeof iconMap

const iconMap = {
  react: ReactIcon,
  astro: AstroIcon,
  tailwind: TailwindIcon,
  laravel: LaravelIcon,
  alpine: AlpineJSIcon,
  node: NodeIcon,
  postgresql: PostgresIcon,
  docker: DockerIcon,
  git: GitIcon,
  github: GithubIcon,
  javascript: JavaScriptIcon,
  typescript: TypeScriptIcon,
  php: PHPIcon,
  next: NextJSIcon
}

const allSkills: { name: string; icon: IconKey }[] = [
  { name: 'React', icon: 'react' },
  { name: 'Astro', icon: 'astro' },
  { name: 'Tailwind CSS', icon: 'tailwind' },
  { name: 'Laravel', icon: 'laravel' },
  { name: 'Alpine.js', icon: 'alpine' },
  { name: 'Node.js', icon: 'node' },
  { name: 'PostgreSQL', icon: 'postgresql' },
  { name: 'Docker', icon: 'docker' },
  { name: 'Git', icon: 'git' },
  { name: 'GitHub', icon: 'github' },
  { name: 'JavaScript', icon: 'javascript' },
  { name: 'TypeScript', icon: 'typescript' },
  { name: 'PHP', icon: 'php' },
  { name: 'Next.js', icon: 'next' }
]
// Dividir la lista en dos sub-arrays
const skillsRow1 = allSkills.slice(0, 7)
const skillsRow2 = allSkills.slice(7, 14)
---

<section
  id="habilidades"
  class="py-20 sm:py-32 bg-gray-50 dark:bg-gray-900 transition-colors duration-500"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-4xl font-extrabold text-gray-900 dark:text-white mb-16 text-center">
      Mi Stack Tecnológico
    </h2>

    {/* WRAPPER DE LA FILA 1 (MOVIMIENTO A LA IZQUIERDA) */}
    <div class="overflow-hidden mb-8">
      <div class="flex whitespace-nowrap animate-skill-scroll-left hover:paused">
        {/* Contenido Original */}
        {
          skillsRow1.map(({ name, icon }) => {
            // Usar el string 'icon' para encontrar el componente real en el map.
            const IconComponent = iconMap[icon]

            // Confirmar que el componente existe antes de renderizar (manejo de errores)
            if (!IconComponent) return null

            return (
              <div class="inline-block flex-shrink-0 w-[calc(100%/6)] p-2">
                <div class="flex flex-col items-center p-4 bg-gray-50 dark:bg-gray-700 rounded-xl shadow-lg hover:shadow-cyan-500/50 transition duration-400 transform hover:-translate-y-1 border border-gray-100 dark:border-gray-700">
                  <div class="w-12 h-12 mb-3 flex items-center justify-center">
                    <IconComponent />
                  </div>
                  <p class="text-lg font-semibold text-gray-800 dark:text-gray-200">{name}</p>
                </div>
              </div>
            )
          })
        }

        {/* Contenido Duplicado */}
        {
          skillsRow1.map(({ name, icon }) => {
            // Usar el string 'icon' para encontrar el componente real en el map.
            const IconComponent = iconMap[icon]

            if (!IconComponent) return null

            return (
              <div class="inline-block flex-shrink-0 w-[calc(100%/6)] p-2">
                <div class="flex flex-col items-center p-4 bg-gray-50 dark:bg-gray-700 rounded-xl shadow-lg hover:shadow-cyan-500/50 transition duration-400 transform hover:-translate-y-1 border border-gray-100 dark:border-gray-700">
                  <div class="w-12 h-12 mb-3 flex items-center justify-center">
                    <IconComponent />
                  </div>
                  <p class="text-lg font-semibold text-gray-800 dark:text-gray-200">{name}</p>
                </div>
              </div>
            )
          })
        }
      </div>
    </div>
    {/* WRAPPER DE LA FILA 2 (MOVIMIENTO A LA DERECHA) */}

    <div class="overflow-hidden">
      <div class="flex whitespace-nowrap animate-skill-scroll-right hover:paused">
        {
          skillsRow2.map(({ name, icon }) => {
            const IconComponent = iconMap[icon]

            if (!IconComponent) return null

            return (
              <div class="inline-block flex-shrink-0 w-[calc(100%/6)] p-2">
                <div class="flex flex-col items-center p-4 bg-gray-50 dark:bg-gray-700 rounded-xl shadow-lg hover:shadow-cyan-500/50 transition duration-400 transform hover:-translate-y-1 border border-gray-100 dark:border-gray-700">
                  <div class="w-12 h-12 mb-3 flex items-center justify-center">
                    <IconComponent />
                  </div>
                  <p class="text-lg font-semibold text-gray-800 dark:text-gray-200">{name}</p>
                </div>
              </div>
            )
          })
        }

        {
          skillsRow2.map(({ name, icon }) => {
            // Usar el string 'icon' para encontrar el componente real en el map.
            const IconComponent = iconMap[icon]

            if (!IconComponent) return null

            return (
              <div class="inline-block flex-shrink-0 w-[calc(100%/6)] p-2">
                <div class="flex flex-col items-center p-4 bg-gray-50 dark:bg-gray-700 rounded-xl shadow-lg hover:shadow-cyan-500/50 transition duration-400 transform hover:-translate-y-1 border border-gray-100 dark:border-gray-700">
                  <div class="w-12 h-12 mb-3 flex items-center justify-center">
                    <IconComponent />
                  </div>
                  <p class="text-lg font-semibold text-gray-800 dark:text-gray-200">{name}</p>
                </div>
              </div>
            )
          })
        }
      </div>
    </div>
  </div>
</section>
