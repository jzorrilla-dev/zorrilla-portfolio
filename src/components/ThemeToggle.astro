---
// El script que se encuentra en theme.js define window.toggleTheme()
---

<button
  id="theme-toggle"
  aria-label="Toggle theme"
  onclick="window.toggleTheme()"
  class="group fixed bottom-10 right-10 z-[100] p-3 rounded-full bg-sky-300 hover:bg-sky-400 text-white shadow-xl transition-colors duration-300 border-2 border-slate-400 dark:bg-gray-800 dark:hover:bg-gray-700 dark:border-gray-500"
>
  <!-- Sol: visible en modo claro en reposo, y en modo oscuro en hover -->
  <svg
    class="h-6 w-6 block dark:hidden group-hover:hidden"
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    fill="#ebe534"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <circle cx="12" cy="12" r="5"></circle>
    <line x1="12" y1="1" x2="12" y2="3"></line>
    <line x1="12" y1="21" x2="12" y2="23"></line>
    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
    <line x1="1" y1="12" x2="3" y2="12"></line>
    <line x1="21" y1="12" x2="23" y2="12"></line>
    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
  </svg>

  <!-- Luna: visible en modo oscuro en reposo, y en modo claro en hover -->
  <svg
    class="h-6 w-6 hidden dark:block dark:group-hover:hidden"
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    fill="#fcfcfc"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
  </svg>

  <!-- Sol hover: aparece en modo oscuro al hacer hover (preview de ir a modo claro) -->
  <svg
    class="h-6 w-6 hidden dark:group-hover:block"
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    fill="#ebe534"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <circle cx="12" cy="12" r="5"></circle>
    <line x1="12" y1="1" x2="12" y2="3"></line>
    <line x1="12" y1="21" x2="12" y2="23"></line>
    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
    <line x1="1" y1="12" x2="3" y2="12"></line>
    <line x1="21" y1="12" x2="23" y2="12"></line>
    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
  </svg>

  <!-- Luna hover: aparece en modo claro al hacer hover (preview de ir a modo oscuro) -->
  <svg
    class="h-6 w-6 hidden group-hover:block dark:group-hover:hidden"
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    fill="#fcfcfc"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
  </svg>
</button>
