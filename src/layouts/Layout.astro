---
import '../styles/global.css'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import ThemeToggle from '../components/ThemeToggle.astro'

// propiedades que el layout puede recibir
interface Props {
  title: string
  description: string
}

declare global {
  interface Window {
    toggleTheme?: () => void
  }
}

const { title, description } = Astro.props
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/logoZ.svg" />
    <meta name="description" content={description} />

    <slot name="head" />
    <script type="module" src="/theme.js"></script>
  </head>
  <body
    class="min-h-screen bg-gray-50 text-gray-900 dark:bg-gray-900 dark:text-gray-100 antialiased selection:bg-cyan-500 selection:text-white flex flex-col overflow-x-hidden"
  >
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <ThemeToggle />
  </body>
</html>

<style is:global>
  html {
    font-family: ui-sans-serif, system-ui, sans-serif;
  }
</style>
